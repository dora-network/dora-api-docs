# DORA REST API connection settings.
# Copy this file to `.env` and fill in your values before running any example:
#
#   cp example.env .env
#
# Do not commit `.env` — it is gitignored.

# Base URL of the DORA REST API. Examples:
#   https://staging.dora.co
#   https://api.dora.co
DORA_BASE_URL=https://staging.dora.co

# Your DORA API key, e.g. `dora.6ilugxx9m51avyhr5yy8.<secret>`.
# Generate one in the DORA UI: user menu -> account settings -> API keys.
DORA_API_KEY=replace-with-your-dora-api-key
